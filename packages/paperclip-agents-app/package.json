{
  "name": "@org-os/paperclip-agents-app",
  "version": "0.1.0",
  "description": "Paperclip as the Agents Application for org-os - Orchestrate agents across organizational instances",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "paperclip-setup": "node src/cli/setup.mjs"
  },
  "scripts": {
    "setup": "node src/cli/setup.mjs",
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "pg": "^8.12.0",
    "js-yaml": "^4.1.0",
    "glob": "^10.4.5",
    "zod": "^3.23.8",
    "pino": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.8",
    "typescript": "^5.5.4",
    "tsx": "^4.17.0",
    "vitest": "^1.6.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "org-os",
    "paperclip",
    "agents",
    "coordination",
    "organizations"
  ]
}
