# Paperclip Agents App Configuration
# Copy this file to .paperclip/.env and configure values

# Server Configuration
PAPERCLIP_PORT=3100
PAPERCLIP_HOST=0.0.0.0

# JWT Authentication (generate a secure secret in production)
PAPERCLIP_JWT_SECRET=your-secure-secret-change-in-production
PAPERCLIP_JWT_EXPIRES_IN=24h

# PostgreSQL Database
PGHOST=localhost
PGPORT=5432
PGDATABASE=paperclip
PGUSER=postgres
PGPASSWORD=your-password-here
PGSSLMODE=disable

# Connection Pool
PGPOOL_SIZE=10

# Logging
LOG_LEVEL=info
LOG_PATH=./logs/paperclip.log

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=1 minute

# CORS
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# Node Environment
NODE_ENV=development
