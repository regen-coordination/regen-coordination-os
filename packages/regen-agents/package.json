{
  "name": "@org-os/regen-agents",
  "version": "0.1.0",
  "description": "Specialist agents for regenerative ecosystem coordination - agriculture, governance, impact, and bioregional intelligence",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./agents": {
      "import": "./dist/agents/index.js",
      "types": "./dist/agents/index.d.ts"
    },
    "./super-agent": {
      "import": "./dist/super-agent/index.js",
      "types": "./dist/super-agent/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@org-os/framework": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "regenerative",
    "agriculture",
    "governance",
    "commons",
    "impact",
    "bioregional",
    "coordination",
    "agents"
  ],
  "license": "MIT"
}
