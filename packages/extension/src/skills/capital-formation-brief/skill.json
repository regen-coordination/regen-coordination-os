{
  "id": "capital-formation-brief",
  "version": "0.1.0",
  "description": "Synthesize high-fit opportunities into a concise review draft for funding and capital formation.",
  "runtime": "extension-offscreen",
  "model": "webllm",
  "triggers": ["high-confidence-draft", "receiver-backlog"],
  "inputSchemaRef": "agent-observation",
  "outputSchemaRef": "capital-formation-brief-output",
  "allowedTools": ["read-observation-context", "read-coop-context", "create-review-draft"],
  "allowedActionClasses": [],
  "requiredCapabilities": ["coop-context", "grant-fit-scores"],
  "approvalMode": "advisory",
  "timeoutMs": 45000,
  "maxTokens": 700,
  "depends": ["grant-fit-scorer"],
  "skipWhen": "no-scores",
  "provides": ["drafts"]
}
