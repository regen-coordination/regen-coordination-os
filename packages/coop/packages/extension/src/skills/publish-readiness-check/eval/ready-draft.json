{
  "id": "ready-draft",
  "description": "Publish readiness checks should preserve draft identity and a bounded recommendation.",
  "output": {
    "draftId": "draft-river-1",
    "ready": true,
    "suggestions": [
      "The title and summary are clear enough for publish.",
      "Keep the current watershed and funding tags."
    ],
    "proposedPatch": {
      "tags": ["watershed", "funding", "restoration"]
    }
  },
  "assertions": [
    { "type": "field-present", "path": "draftId" },
    { "type": "field-equals", "path": "ready", "expected": true },
    { "type": "array-min-length", "path": "suggestions", "threshold": 1 },
    { "type": "semantic-word-count", "path": "suggestions.0", "threshold": 5 },
    { "type": "string-min-length", "path": "draftId", "threshold": 3 }
  ]
}
