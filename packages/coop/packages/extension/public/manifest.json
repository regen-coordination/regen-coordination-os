{
  "manifest_version": 3,
  "name": "Coop v1",
  "version": "0.1.0",
  "description": "Browser-first shared intelligence for coordinated communities.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "sidePanel",
    "activeTab",
    "offscreen",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1/*", "http://localhost/*"],
      "js": ["receiver-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Coop",
    "default_popup": "popup.html"
  },
  "commands": {
    "open-sidepanel": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the Coop sidepanel"
    },
    "round-up-tab": {
      "suggested_key": {
        "default": "Alt+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Round up the active tab into Coop"
    },
    "capture-screenshot": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Capture the visible tab as a private Coop screenshot"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
