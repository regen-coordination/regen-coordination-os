{
  "name": "@org-os/koi-opal-bridge",
  "version": "1.0.0",
  "description": "Bridge between OPAL (AI knowledge gardens) and KOI (distributed knowledge graphs) for Organizational OS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint src/",
    "setup": "node dist/scripts/setup.js",
    "sync-loop": "node dist/scripts/sync-loop.js"
  },
  "bin": {
    "koi-opal": "dist/cli.js"
  },
  "keywords": [
    "koi",
    "opal",
    "knowledge-commons",
    "organizational-os",
    "regen-agency",
    "ai-librarian",
    "knowledge-graph",
    "federation"
  ],
  "author": "Organizational OS / Regen Agency",
  "license": "MIT",
  "dependencies": {
    "yaml": "^2.3.4",
    "node-fetch": "^3.3.2",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0"
  },
  "peerDependencies": {
    "@koi-net-integration/koi-bridge": ">=1.0.0",
    "@koi-net-integration/knowledge-api": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/luizfernandosg/org-os",
    "directory": "packages/koi-opal-bridge"
  }
}
