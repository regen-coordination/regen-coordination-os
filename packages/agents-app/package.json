{
  "name": "@org-os/agents-app",
  "version": "0.1.0",
  "description": "Paperclip-based Agents Application for org-os - Orchestrate AI agents with a visual dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "org-os-agents": "./scripts/cli.mjs"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:ui\"",
    "dev:server": "tsx watch src/core/server/index.ts",
    "dev:ui": "vite",
    "build": "tsc && vite build",
    "sync": "node scripts/sync.mjs",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "fastify": "^4.28.1",
    "glob": "^10.4.5",
    "inquirer": "^9.3.6",
    "js-yaml": "^4.1.0",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.8",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "keywords": [
    "org-os",
    "agents",
    "ai",
    "orchestration",
    "paperclip",
    "dashboard",
    "coordination"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/regen-coordination/org-os",
    "directory": "packages/agents-app"
  }
}